{
  // Let the Solidity extension resolve imports from npm packages.
  // Works with Juan Blanco Solidity extension and compatible language servers.
  "solidity.packageDefaultDependenciesDirectory": "node_modules",
  "solidity.packageDefaultDependenciesContractsDirectory": "contracts",

  // Remap @openzeppelin/* to node_modules so imports like
  // import "@openzeppelin/contracts-upgradeable/..." resolve.
  "solidity.remappings": [
    "@openzeppelin/=node_modules/@openzeppelin/"
  ]
}
